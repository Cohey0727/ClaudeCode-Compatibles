#!/usr/bin/env bash
# Launch Claude Code against an Anthropic-compatible provider.
#
# Generated by `make install`. The PROVIDER_DIR path below is baked in
# from the directory you ran `make install` from. Re-run `make install`
# if you move the project.

set -euo pipefail

PROVIDER_DIR="@@PROVIDER_DIR@@"
CONFIG_FILE="$PROVIDER_DIR/config"
ENV_FILE="$PROVIDER_DIR/.env"

if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "launcher: provider config not found at $CONFIG_FILE" >&2
  echo "  re-run 'make install' from the project root." >&2
  exit 1
fi

# Provider definition (non-secret): COMMAND, BASE_URL, KEY_VAR, DEFAULT_* ...
# Sourced plainly so these stay local and don't leak into claude's environment.
# shellcheck disable=SC1090
source "$CONFIG_FILE"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "${COMMAND:-launcher}: env file not found at $ENV_FILE" >&2
  echo "  re-run 'make install' from the project root." >&2
  exit 1
fi

# Load the user's secrets/overrides and auto-export them. Any extra KEY=VALUE
# pairs the user adds to .env are passed through to claude as well.
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

# Resolve the API key from whichever variable this provider uses.
KEY_VALUE="${!KEY_VAR:-}"
if [[ -z "$KEY_VALUE" ]]; then
  echo "$COMMAND: $KEY_VAR is empty in $ENV_FILE" >&2
  echo "  edit the file and set $KEY_VAR=${KEY_HINT:-<your-api-key>}" >&2
  exit 1
fi

export ANTHROPIC_BASE_URL="$BASE_URL"
export ANTHROPIC_AUTH_TOKEN="$KEY_VALUE"

# Export a variable using: existing env override > provider default > skip.
maybe_export() {
  local var="$1" def="$2"
  local val="${!var:-}"
  val="${val:-$def}"
  if [[ -n "$val" ]]; then export "$var=$val"; fi
}

maybe_export ANTHROPIC_MODEL                 "${DEFAULT_MODEL:-}"
maybe_export ANTHROPIC_DEFAULT_OPUS_MODEL    "${DEFAULT_OPUS:-}"
maybe_export ANTHROPIC_DEFAULT_SONNET_MODEL  "${DEFAULT_SONNET:-}"
maybe_export ANTHROPIC_DEFAULT_HAIKU_MODEL   "${DEFAULT_HAIKU:-}"
maybe_export CLAUDE_CODE_SUBAGENT_MODEL      "${DEFAULT_SUBAGENT:-}"
maybe_export CLAUDE_CODE_EFFORT_LEVEL        "${DEFAULT_EFFORT:-}"
maybe_export API_TIMEOUT_MS                  "${DEFAULT_API_TIMEOUT_MS:-}"
maybe_export CLAUDE_CODE_AUTO_COMPACT_WINDOW "${DEFAULT_AUTO_COMPACT_WINDOW:-}"

# A stale ANTHROPIC_API_KEY in the environment would shadow AUTH_TOKEN.
unset ANTHROPIC_API_KEY

exec claude "$@"
