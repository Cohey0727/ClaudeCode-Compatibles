#!/usr/bin/env bash
# Launch Claude Code against an Anthropic-compatible provider.
#
# Generated by `make install`. The PROVIDER_DIR path below is baked in
# from the directory you ran `make install` from. Re-run `make install`
# if you move the project.

set -euo pipefail

PROVIDER_DIR="@@PROVIDER_DIR@@"
ENV_FILE="$PROVIDER_DIR/.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "launcher: env file not found at $ENV_FILE" >&2
  echo "  re-run 'make install' from the project root." >&2
  exit 1
fi

# .env is the single source of truth: ANTHROPIC_* / CLAUDE_CODE_* variables
# (and any extra KEY=VALUE pairs) are exported to claude verbatim.
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

NAME="${COMMAND:-launcher}"
# COMMAND is launcher metadata for `make install`, not for claude.
unset COMMAND

if [[ -z "${ANTHROPIC_AUTH_TOKEN:-}" ]]; then
  echo "$NAME: ANTHROPIC_AUTH_TOKEN is empty in $ENV_FILE" >&2
  echo "  edit the file and set your API key." >&2
  exit 1
fi

if [[ -z "${ANTHROPIC_BASE_URL:-}" ]]; then
  echo "$NAME: ANTHROPIC_BASE_URL is empty in $ENV_FILE" >&2
  exit 1
fi

# A stale ANTHROPIC_API_KEY in the environment would shadow AUTH_TOKEN.
unset ANTHROPIC_API_KEY

exec claude "$@"
