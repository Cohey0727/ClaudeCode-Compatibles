# Kimi (Moonshot AI) launcher settings. Every variable here is exported to claude as-is.
# Reference: https://platform.moonshot.ai/docs
#
# COMMAND is only the installed launcher name (read by `make install`,
# stripped before claude starts).
COMMAND=kimi

# Optional: default CLI options prepended to every launch (word-split, then
# stripped before claude starts). Explicit options on the command line come
# after these, e.g. CLAUDE_ARGS="--verbose --permission-mode plan"
CLAUDE_ARGS=

# Required: get an API key at https://platform.moonshot.ai/console/api-keys
ANTHROPIC_AUTH_TOKEN=

ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
ANTHROPIC_MODEL=kimi-k3[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-k3[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-k3[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-k3[1m]
ANTHROPIC_DEFAULT_FABLE_MODEL=kimi-k3[1m]
CLAUDE_CODE_SUBAGENT_MODEL=kimi-k3[1m]
ENABLE_TOOL_SEARCH=false
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1048576
CLAUDE_CODE_EFFORT_LEVEL=max
