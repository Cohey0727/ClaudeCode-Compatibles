# GLM (Z.ai / Zhipu AI) launcher settings. Every variable here is exported to claude as-is.
# Reference: https://docs.z.ai/devpack/tool/claude
#
# COMMAND is only the installed launcher name (read by `make setup`,
# stripped before claude starts).
COMMAND=glm

# Optional: default CLI options prepended to every launch (word-split, then
# stripped before claude starts). Explicit options on the command line come
# after these, e.g. CLAUDE_ARGS="--verbose --permission-mode plan"
CLAUDE_ARGS=

# Required: get an API key at https://z.ai/manage-apikey/apikey-list
ANTHROPIC_AUTH_TOKEN=

ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=glm-5.2
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
ANTHROPIC_DEFAULT_FABLE_MODEL=glm-5.2
CLAUDE_CODE_SUBAGENT_MODEL=glm-4.5-air
CLAUDE_CODE_EFFORT_LEVEL=max
