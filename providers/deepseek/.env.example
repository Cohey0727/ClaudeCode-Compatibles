# DeepSeek launcher settings. Every variable here is exported to claude as-is.
# Reference: https://api-docs.deepseek.com/guides/agent_integrations/claude_code
#
# COMMAND is only the installed launcher name (read by `make install`,
# stripped before claude starts).
COMMAND=deepseek

# Required: get an API key at https://platform.deepseek.com/
ANTHROPIC_AUTH_TOKEN=

ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max
