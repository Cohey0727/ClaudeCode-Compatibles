# MiniMax launcher settings. Every variable here is exported to claude as-is.
#
# COMMAND is only the installed launcher name (read by `make install`,
# stripped before claude starts). It is "mmxcode", not "minimax" or "mmx":
# both shorter names already exist on a typical machine and would collide —
#   minimax -> ~/.mavis/bin/minimax (official MiniMax Code desktop app)
#   mmx     -> ~/.bun/bin/mmx (unrelated bun-installed tool)
COMMAND=mmxcode

# Required: get an API key at https://www.minimax.io/platform
ANTHROPIC_AUTH_TOKEN=

ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_MODEL=MiniMax-M3
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M3
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M3
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M3
CLAUDE_CODE_SUBAGENT_MODEL=MiniMax-M3
CLAUDE_CODE_EFFORT_LEVEL=max
